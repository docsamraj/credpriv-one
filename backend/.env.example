DATABASE_URL="postgresql://postgres:postgres@localhost:5432/credpriv?schema=public"
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads

ENABLE_EXPIRY_REMINDERS=true

# Document gate — set true to block credentialing until required docs are uploaded
ENFORCE_DOCUMENT_GATE=false

# Email (optional — MoM and status notifications use SMTP when configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CredPriv One <noreply@credpriv.hospital>"

# Integration API key for machine-to-machine exports (optional)
INTEGRATION_API_KEY=

# Cloudflare AI — job description privilege extraction (optional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
CLOUDFLARE_AI_GATEWAY_ID=
